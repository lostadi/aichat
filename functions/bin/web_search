#!/bin/sh

# Web search tool using SearXNG
# Expects a JSON string as the first argument, e.g., {"query": "search terms"}
# Outputs a JSON string representing search results

# Configuration
SEARXNG_URL="${SEARXNG_URL:-http://localhost:8080}"
TIMEOUT=10

# Extract the query
if command -v jq >/dev/null 2>&1; then
    query=$(echo "$1" | jq -r '.query')
else
    # Fallback: simple parsing, might fail on complex JSON
    query=$(echo "$1" | sed -n 's/.*"query"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
fi

if [ -z "$query" ] || [ "$query" = "null" ]; then
    echo '{"error": "No query provided", "results": []}'
    exit 1
fi

# URL encode the query
encoded_query=$(printf '%s' "$query" | sed 's/ /+/g; s/[^a-zA-Z0-9+_.~-]/%&/g' | tr '[:lower:]' '[:upper:]' | sed 's/%\(..\)/%\L\1/g')

# Make the request to SearXNG
response=$(curl -s --connect-timeout 5 --max-time "$TIMEOUT" \
    -H "Accept: application/json" \
    "${SEARXNG_URL}/search?q=${encoded_query}&format=json" 2>/dev/null)

if [ $? -ne 0 ] || [ -z "$response" ]; then
    # SearXNG not available - try to auto-start
    SCRIPT_PATH="scripts/searxng/manage_searxng.sh"
    
    # Check if we can find the management script
    if [ ! -f "$SCRIPT_PATH" ]; then
        # Try looking one level up or in common locations if needed, but for now stick to CWD assumption from main.rs
        cat <<EOF
{
  "error": "SearXNG not available at ${SEARXNG_URL}. Could not find ${SCRIPT_PATH} to auto-start it.",
  "results": []
}
EOF
        exit 0
    fi

    # Auto-start SearXNG
    # We output a message to stderr so it doesn't break JSON output for the tool user (but user on CLI sees it)
    echo "SearXNG not reachable. Attempting to start it via ${SCRIPT_PATH}..." >&2
    bash "$SCRIPT_PATH" start >&2
    
    if [ $? -ne 0 ]; then
         cat <<EOF
{
  "error": "Failed to auto-start SearXNG.",
  "results": []
}
EOF
        exit 0
    fi

    # Wait for it to be ready (up to 20 seconds)
    echo "Waiting for SearXNG to be ready..." >&2
    for i in $(seq 1 20); do
        curl -s -m 1 "${SEARXNG_URL}" >/dev/null
        if [ $? -eq 0 ]; then
            echo "SearXNG is up!" >&2
            break
        fi
        sleep 1
    done

    # Retry the request
    response=$(curl -s --connect-timeout 5 --max-time "$TIMEOUT" \
        -H "Accept: application/json" \
        "${SEARXNG_URL}/search?q=${encoded_query}&format=json" 2>/dev/null)
        
    if [ $? -ne 0 ] || [ -z "$response" ]; then
        cat <<EOF
{
  "error": "SearXNG started but still not reachable at ${SEARXNG_URL}.",
  "results": []
}
EOF
        exit 0
    fi
fi

# Check if jq is available for proper JSON parsing
if command -v jq >/dev/null 2>&1; then
    # Use jq for proper JSON extraction
    echo "$response" | jq -c '{
        results: [.results[:10][] | {
            title: .title,
            url: .url,
            snippet: (.content // .snippet // "No description available")
        }]
    }' 2>/dev/null
    
    if [ $? -ne 0 ]; then
        # jq failed, response might not be valid JSON
        echo '{"error": "Invalid response from SearXNG", "results": []}'
    fi
else
    # Fallback: basic parsing without jq
    # Extract up to 5 results using sed/awk (limited but works)
    echo "$response" | grep -o '"title":"[^"]*"' | head -5 | while read -r line; do
        title=$(echo "$line" | sed 's/"title":"\([^"]*\)"/\1/')
        echo "  - $title"
    done
    
    # For actual JSON output, we need jq - output a warning
    cat <<EOF
{
  "warning": "Install jq for better JSON parsing",
  "raw_response_available": true,
  "results": []
}
EOF
fi
